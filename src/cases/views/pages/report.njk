{% extends '../layouts/case-layout.njk' %}
{% from "govuk/components/select/macro.njk" import govukSelect %}
{% from "govuk/components/button/macro.njk" import govukButton %}
{% from "govuk/components/table/macro.njk" import govukTable %}

{% block contentMain %}
  <div class="govuk-grid-row">
    <div class="govuk-grid-column-two-thirds">
      {{ heading({ text: pageHeading }) }}

      <p class="govuk-body">
        The number of cases at each lifecycle position (phase, then stage, then
        status), for the selected case type.
      </p>

      <form method="GET" action="/reports">
        {{
          govukSelect({
            id: "workflowCode",
            name: "workflowCode",
            label: { text: "Case type", classes: "govuk-label--s" },
            items: data.caseTypeItems
          })
        }}
        {{ govukButton({ text: "Update report" }) }}
      </form>

      {% if data.hasResults %}
        <p class="govuk-body" data-testid="report-total">
          Showing <strong>{{ data.total }}</strong>
          {{ data.selectedCaseTypeLabel }} case(s).
        </p>

        {{
          govukTable({
            attributes: { "data-testid": "report-table" },
            head: [
              { text: "Phase / stage / status" },
              { text: "Cases", format: "numeric" }
            ],
            rows: data.table.rows
          })
        }}
      {% else %}
        <p class="govuk-body" data-testid="report-empty">
          No cases found for this case type.
        </p>
      {% endif %}
    </div>
  </div>
{% endblock %}
